---
import AppIcon from './AppIcon.astro';
import { fetchPosts, type Post } from '../lib/api';
import { newsItems } from '../data/homepage';

interface NewsCardItem {
  title: string;
  summary: string;
  date: string;
  category: string;
  link: string;
  image: string | null;
  imageAlt: string;
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' });
}

function firstTag(tags: string[] | null): string {
  if (!tags || tags.length === 0) return 'Gelişme';
  return tags[0].charAt(0).toUpperCase() + tags[0].slice(1);
}

function normalizePost(post: Post): NewsCardItem {
  return {
    title: post.title,
    summary: post.summary || 'İçeriğin kısa özeti yakında burada yer alacak.',
    date: formatDate(post.published_at),
    category: firstTag(post.tags),
    link: `/post/${post.slug}`,
    image: post.cover_image,
    imageAlt: post.title,
  };
}

let sectionItems: NewsCardItem[] = newsItems.map((item) => ({
  ...item,
  image: item.image,
}));

try {
  const posts = await fetchPosts();

  posts.sort((a, b) => {
    if (!a.published_at) return 1;
    if (!b.published_at) return -1;
    return new Date(b.published_at).getTime() - new Date(a.published_at).getTime();
  });

  const normalizedPosts = posts.slice(0, 4).map(normalizePost);
  if (normalizedPosts.length > 0) {
    sectionItems = normalizedPosts;
  }
} catch (e) {
  console.error('[homepage/news] API fetch failed:', e);
}

const [featuredItem, ...secondaryItems] = sectionItems;
---

<section class="section-space">
  <div class="mx-auto w-full max-w-[84rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-12 grid gap-7 xl:grid-cols-[minmax(0,1.18fr)_minmax(24rem,0.72fr)] xl:items-end 2xl:grid-cols-[minmax(0,1.24fr)_minmax(25rem,0.68fr)]">
      <div class="max-w-[58rem] space-y-4">
        <span class="eyebrow">Gelişmeler</span>
        <h2 class="section-title max-w-[18ch] xl:max-w-[17ch]">
          Derneğin gündemini, projelerini ve saha temaslarını takip et.
        </h2>
      </div>

      <div class="flex flex-col gap-5 xl:items-start xl:justify-end xl:pb-1">
        <p class="max-w-[29rem] text-lg leading-8 text-black/68">
          Son içerikleri daha kısa ve net bir akışta burada bulabilirsin.
        </p>

        <a href="/gelismeler" class="btn w-fit rounded-full border-[color:var(--brand-outline)] bg-white px-6 text-[#1B1B1B] shadow-none hover:border-[#FF9700]/30 hover:bg-[#FF9700] hover:text-white">
          Bütün Gelişmeler
        </a>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1.16fr)_minmax(23rem,0.84fr)] xl:items-start 2xl:grid-cols-[minmax(0,1.2fr)_minmax(24rem,0.8fr)]">
      <article class="surface-card overflow-hidden self-start transition duration-300 hover:border-[#FF9700]/24 hover:shadow-[0_24px_60px_rgba(255,151,0,0.14)]">
        <a href={featuredItem.link} class="group block h-full">
          <div class="grid gap-0 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
            <div class="relative min-h-[280px] overflow-hidden bg-[#F5F5F7] lg:min-h-full">
              {featuredItem.image ? (
                <img
                  src={featuredItem.image}
                  alt={featuredItem.imageAlt}
                  class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.03]"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center bg-[linear-gradient(180deg,rgba(255,151,0,0.12),rgba(27,27,27,0.08))]">
                  <span class="icon-chip h-20 w-20 rounded-[1.6rem] border-white/30 bg-white/30 text-[#1B1B1B]/50 shadow-none">
                    <AppIcon name="document" class="h-8 w-8" />
                  </span>
                </div>
              )}
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(27,27,27,0.06),rgba(27,27,27,0.32))]"></div>
              <div class="absolute left-5 top-5 inline-flex rounded-full border border-white/25 bg-white/88 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-[#1B1B1B] backdrop-blur-sm">
                {featuredItem.category}
              </div>
            </div>

            <div class="flex h-full flex-col justify-between p-7 sm:p-8">
              <div>
                <p class="text-primary text-sm font-semibold uppercase tracking-[0.18em]">{featuredItem.date}</p>
                <h3 class="mt-4 max-w-[16ch] font-display text-[2rem] font-bold leading-[1.04] text-[#1B1B1B] transition group-hover:text-[#FF9700] sm:text-[2.3rem]">
                  {featuredItem.title}
                </h3>
                <p class="text-clamp-3 mt-5 max-w-[32rem] text-base leading-8 text-[#1B1B1B]/70">
                  {featuredItem.summary}
                </p>
              </div>

              <div class="mt-8 flex flex-col gap-4 border-t border-[color:var(--brand-outline)] pt-5 sm:flex-row sm:items-end sm:justify-between">
                <p class="max-w-[22rem] text-sm leading-7 text-[#1B1B1B]/58">
                  Öne çıkan gelişmenin kısa özeti ve detay bağlantısı.
                </p>
                <span class="inline-flex items-center gap-2 text-sm font-semibold text-[#1B1B1B] transition group-hover:text-[#FF9700]">
                  Devamını Oku
                  <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
                </span>
              </div>
            </div>
          </div>
        </a>
      </article>

      <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-1">
        {secondaryItems.map((item) => (
          <article class="surface-card overflow-hidden transition duration-300 hover:border-[#FF9700]/24 hover:shadow-[0_20px_48px_rgba(255,151,0,0.12)]">
            <a href={item.link} class="group grid h-full md:grid-cols-[220px_1fr]">
              <div class="relative min-h-[200px] overflow-hidden md:min-h-full">
                {item.image ? (
                  <img
                    src={item.image}
                    alt={item.imageAlt}
                    class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-[#FF9700]/15 to-[#1B1B1B]/10">
                    <span class="icon-chip h-16 w-16 rounded-[1.25rem] border-white/30 bg-white/20 text-[#1B1B1B]/45 shadow-none">
                      <AppIcon name="document" class="h-6 w-6" />
                    </span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
              </div>

              <div class="flex flex-col p-6">
                <div class="inline-flex w-fit rounded-full border border-[color:var(--brand-outline)] bg-[#F5F5F7] px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-[#1B1B1B]">
                  {item.category}
                </div>
                <p class="text-primary mt-4 text-xs font-semibold uppercase tracking-[0.18em]">{item.date}</p>
                <h3 class="mt-3 max-w-[18ch] font-display text-[1.45rem] font-bold leading-[1.08] text-[#1B1B1B] transition group-hover:text-[#FF9700]">
                  {item.title}
                </h3>
                <p class="text-clamp-3 mt-3 text-sm leading-7 text-[#1B1B1B]/70">{item.summary}</p>
                <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[#1B1B1B] transition group-hover:text-[#FF9700]">
                  İncele
                  <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
