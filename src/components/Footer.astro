---
const footerGroups = [
  {
    title: 'Kurumsal',
    links: [
      { name: 'Hakkımızda', href: '/hakkimizda' },
      { name: 'Yönetim Kurulumuz', href: '/yonetim-kurulumuz' },
      { name: 'İletişim', href: '/iletisim' },
    ],
  },
  {
    title: 'Projeler & Destek',
    links: [
      { name: 'Projelerimiz', href: '/projelerimiz' },
      { name: 'Saha Projeleri', href: '/saha-projeleri' },
      { name: 'Ulaşım Desteği', href: '/ulasim-destegi' },
      { name: 'Psikolojik Destek', href: '/psikolojik-destek' },
      { name: 'Kariyer Desteği', href: '/kariyer-gelisim-detegi' },
    ],
  },
  {
    title: 'Hızlı Bağlantılar',
    links: [
      { name: 'Üye Ol', href: '/uye-ol' },
      { name: 'Bağışçı Ol', href: '/bagisci-ol' },
      { name: 'S.S.S.', href: '/sikca-sorulan-sorular' },
      { name: 'Gelişmeler', href: '/gelismeler' },
    ],
  },
];
---

<footer class="mt-20 bg-[#1B1B1B] text-white">
  <div class="site-shell grid gap-10 py-16 lg:grid-cols-[1.2fr_0.72fr_0.9fr_0.82fr] lg:gap-8">
    <aside class="space-y-6">
      <img src="/home/logo-footer.png" alt="itüöder logo" class="h-8 w-auto object-contain" />
      <p class="max-w-sm text-base leading-7 text-white/68">
        İstanbul Teknik Üniversitesi Öğrenci Derneği.
        Öğrencilerin yanında, değişimin öncüsü.
      </p>
      <div class="space-y-2 text-sm text-white/58">
        <a href="mailto:dernek@ituogrenci.org.tr" class="inline-flex w-fit font-semibold text-white transition hover:text-[#FF9700]">
          dernek@ituogrenci.org.tr
        </a>
        <p>www.ituogrenci.org.tr</p>
      </div>
    </aside>

    {footerGroups.map((group) => (
      <nav class="space-y-4">
        <h6 class="font-display text-sm font-semibold uppercase tracking-[0.24em] text-white/38">{group.title}</h6>
        <div class="flex flex-col gap-3 text-sm text-white/68">
          {group.links.map((link) => (
            <a href={link.href} class="w-fit transition hover:text-[#FF9700]">{link.name}</a>
          ))}
        </div>
      </nav>
    ))}
  </div>

  <div class="border-t border-white/8 bg-[#000000]">
    <div class="site-shell flex flex-col gap-4 py-6 text-sm text-white/56 md:flex-row md:items-center md:justify-between">
      <p class="max-w-[42rem]">
        Tüm Hakları Saklıdır © 2025 İstanbul Teknik Üniversitesi Öğrencileri Derneği.
        <span class="block text-xs text-white/40">Bu websitesi İTÜ Öğrencileri tarafından yapılmıştır.</span>
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/kullanim-ve-gizlilik-politikası" class="w-fit transition hover:text-[#FF9700]">Gizlilik Politikası</a>
        <a href="/haklisin-acik-riza-metni" class="w-fit transition hover:text-[#FF9700]">Açık Rıza Metni</a>
      </div>
    </div>
  </div>
</footer>
