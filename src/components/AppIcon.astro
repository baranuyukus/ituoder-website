---
import { iconPaths, type AppIconName } from '../lib/icons';

interface Props {
  name: AppIconName;
  class?: string;
  strokeWidth?: number;
}

const { name, class: className = 'h-5 w-5', strokeWidth = 1.75 } = Astro.props;
const iconMarkup = iconPaths[name] ?? iconPaths.projects;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <Fragment set:html={iconMarkup} />
</svg>
