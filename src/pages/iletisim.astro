---
import Layout from '../layouts/Layout.astro';
import AppIcon from '../components/AppIcon.astro';
---

<Layout title="itüöder - İletişim">

  <!-- ─── HERO ─── -->
  <section class="section-space relative overflow-hidden">
    <div class="pointer-events-none absolute -top-28 right-0 h-[28rem] w-[28rem] rounded-full bg-[#FF9700]/8 blur-[120px]"></div>
    <div class="pointer-events-none absolute bottom-0 left-0 h-64 w-64 rounded-full bg-[#FF9700]/6 blur-[100px]"></div>

    <div class="site-shell relative z-10">
      <div class="mx-auto max-w-3xl text-center">
        <span class="eyebrow mb-6 inline-block">Bize Ulaş</span>
        <h1 class="section-title mb-6">
          İletişim
        </h1>
        <p class="text-base leading-relaxed text-black/70 sm:text-lg sm:leading-relaxed">
          Bize iletmek istediğin herhangi bir sorunun, paylaşmak istediğin bir fikrin, destek olmak istediğin bir projen varsa veya sadece "Merhaba!" demek istersen bizimle iletişime geçmekten çekinme.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── MAIN CONTENT ─── -->
  <section class="section-space-tight">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[0.42fr_0.58fr] lg:items-start">

        <!-- LEFT: İletişim Bilgileri -->
        <div class="space-y-6">
          <!-- E-posta kartı -->
          <div class="surface-card group overflow-hidden p-7 transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(255,151,0,0.1)]">
            <div class="icon-chip mx-auto mb-4 h-14 w-14 rounded-2xl text-[#FF9700]">
              <AppIcon name="email" class="h-6 w-6" />
            </div>
            <h3 class="mb-2 text-center text-lg font-bold text-black">E-posta</h3>
            <a href="mailto:dernek@ituogrenci.org.tr" class="block text-center text-sm font-semibold text-[#FF9700] transition hover:text-[#FF9700]">
              dernek@ituogrenci.org.tr
            </a>
          </div>

          <!-- Sosyal Medya kartı -->
          <div class="surface-card overflow-hidden p-7">
            <div class="icon-chip mx-auto mb-4 h-14 w-14 rounded-2xl text-[#FF9700]">
              <AppIcon name="globe" class="h-6 w-6" />
            </div>
            <h3 class="mb-4 text-center text-lg font-bold text-black">Sosyal Medya</h3>
            <div class="flex flex-wrap justify-center gap-3">
              <a href="https://www.instagram.com/ituogrenci" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2.5 text-xs font-semibold text-black transition hover:-translate-y-0.5 hover:border-[#FF9700]/30 hover:shadow-[0_8px_24px_rgba(255,151,0,0.12)]">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                Instagram
              </a>
              <a href="https://x.com/ituogrenci" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2.5 text-xs font-semibold text-black transition hover:-translate-y-0.5 hover:border-[#FF9700]/30 hover:shadow-[0_8px_24px_rgba(255,151,0,0.12)]">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X (Twitter)
              </a>
              <a href="https://www.linkedin.com/company/ituogrenci" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2.5 text-xs font-semibold text-black transition hover:-translate-y-0.5 hover:border-[#FF9700]/30 hover:shadow-[0_8px_24px_rgba(255,151,0,0.12)]">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <!-- Web kartı -->
          <div class="surface-card overflow-hidden p-7">
            <div class="icon-chip mx-auto mb-4 h-14 w-14 rounded-2xl text-[#FF9700]">
              <AppIcon name="campus" class="h-6 w-6" />
            </div>
            <h3 class="mb-2 text-center text-lg font-bold text-black">Web</h3>
            <a href="https://www.ituogrenci.org.tr" target="_blank" rel="noopener noreferrer" class="block text-center text-sm font-semibold text-[#FF9700] transition hover:text-[#FF9700]">
              www.ituogrenci.org.tr
            </a>
          </div>

          <!-- Bilgi notu -->
          <div class="rounded-2xl border border-[#FF9700]/20 bg-[#F5F5F7] p-5">
            <p class="text-sm leading-relaxed text-black/70">
              <span class="font-semibold text-black">Üyeliğini iptal etmek mi istiyorsun?</span><br />
              İptal talep formunu doldurabilirsin. En geç 5 günde iptalini gerçekleştireceğiz.
            </p>
          </div>
        </div>

        <!-- RIGHT: İletişim Formu -->
        <div class="surface-card overflow-hidden p-8 sm:p-10">
          <div class="mb-8">
            <span class="eyebrow mb-3 inline-block">Mesaj Gönder</span>
            <h2 class="font-display text-2xl font-bold text-black sm:text-3xl">
              Bizimle <span class="text-[#FF9700]">iletişime</span> geç
            </h2>
          </div>

          <form id="contact-form" class="space-y-5">
            <!-- Ad Soyad -->
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="firstName" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-black/50">Ad</label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  required
                  placeholder="Adın"
                  class="w-full rounded-xl border border-black/10 bg-white/80 px-4 py-3 text-sm text-black placeholder:text-black/30 transition focus:border-[#FF9700] focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#FF9700]/20"
                />
              </div>
              <div>
                <label for="lastName" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-black/50">Soyad</label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  required
                  placeholder="Soyadın"
                  class="w-full rounded-xl border border-black/10 bg-white/80 px-4 py-3 text-sm text-black placeholder:text-black/30 transition focus:border-[#FF9700] focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#FF9700]/20"
                />
              </div>
            </div>

            <!-- E-posta -->
            <div>
              <label for="email" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-black/50">E-posta</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="ornek@itu.edu.tr"
                class="w-full rounded-xl border border-black/10 bg-white/80 px-4 py-3 text-sm text-black placeholder:text-black/30 transition focus:border-[#FF9700] focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#FF9700]/20"
              />
            </div>

            <!-- Konu -->
            <div>
              <label for="subject" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-black/50">Konu</label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full rounded-xl border border-black/10 bg-white/80 px-4 py-3 text-sm text-black transition focus:border-[#FF9700] focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#FF9700]/20"
              >
                <option value="" disabled selected>Bir konu seçin</option>
                <option value="genel">Genel Soru</option>
                <option value="uyelik">Üyelik İşlemleri</option>
                <option value="proje">Proje Önerisi</option>
                <option value="isbirligi">İş Birliği</option>
                <option value="destek">Destek Talebi</option>
                <option value="bagiş">Bağış</option>
                <option value="diger">Diğer</option>
              </select>
            </div>

            <!-- Mesaj -->
            <div>
              <label for="message" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-black/50">Mesajın</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Mesajınızı buraya yazabilirsiniz..."
                class="w-full resize-none rounded-xl border border-black/10 bg-white/80 px-4 py-3 text-sm leading-relaxed text-black placeholder:text-black/30 transition focus:border-[#FF9700] focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#FF9700]/20"
              ></textarea>
            </div>

            <!-- Gönder -->
            <button
              type="submit"
              class="btn btn-primary w-full rounded-full px-8 py-3.5 text-sm font-semibold shadow-[0_12px_30px_rgba(255,151,0,0.28)] transition duration-300 hover:shadow-[0_18px_40px_rgba(255,151,0,0.35)]"
            >
              Mesajı Gönder
            </button>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="form-success" class="hidden mt-6 rounded-2xl border border-green-200 bg-green-50 p-5 text-center">
            <span class="mx-auto inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-green-200 bg-white text-green-600">
              <AppIcon name="success" class="h-5 w-5" />
            </span>
            <p class="mt-2 text-sm font-semibold text-green-800">Mesajın başarıyla gönderildi!</p>
            <p class="mt-1 text-xs text-green-600">En kısa sürede sana dönüş yapacağız.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── MAP / LOKASYON ─── -->
  <section class="section-space">
    <div class="site-shell">
      <div class="mb-10 text-center">
        <span class="eyebrow mb-4 inline-block">Lokasyon</span>
        <h2 class="section-title">
          Neredeyiz?
        </h2>
      </div>
      <div class="surface-card overflow-hidden">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3008.478!2d29.0244!3d41.1055!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab7a2ddfb86e7%3A0x3d0c2e7fab0b9e18!2sIstanbul%20Technical%20University!5e0!3m2!1str!2str!4v1710000000000!5m2!1str!2str"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="rounded-[1.9rem]"
          title="İTÜ Ayazağa Kampüsü"
        ></iframe>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Simulate form submission
    form.classList.add('hidden');
    successMsg?.classList.remove('hidden');
  });
</script>
