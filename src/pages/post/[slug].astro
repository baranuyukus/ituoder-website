---
import Layout from '../../layouts/Layout.astro';
import AppIcon from '../../components/AppIcon.astro';
import { fetchPosts, fetchPost } from '../../lib/api';
import type { Post } from '../../lib/api';

// ─── SSG: tüm post slug'larından statik path'ler üret ─────────────────────────
export async function getStaticPaths() {
  try {
    const posts = await fetchPosts();
    return posts.map((post) => ({
      params: { slug: post.slug },
      props: { previewData: post },
    }));
  } catch (e) {
    console.error('[post/[slug]] getStaticPaths API error:', e);
    return [];
  }
}

// ─── Her sayfa için tam içeriği çek ───────────────────────────────────────────
const { slug } = Astro.params;
const { previewData } = Astro.props as { previewData: Post };

let post: Post | null = null;
let fetchError = false;

try {
  post = await fetchPost(slug as string);
} catch (e) {
  console.error(`[post/${slug}] fetchPost error:`, e);
  // getStaticPaths'ten gelen previewData'yı fallback olarak kullan
  post = previewData ?? null;
  fetchError = true;
}

// Tarih formatlama
function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('tr-TR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

function firstTag(tags: string[] | null): string {
  if (!tags || tags.length === 0) return 'Gelişme';
  return tags[0].charAt(0).toUpperCase() + tags[0].slice(1);
}

// 404 fallback
if (!post) {
  return Astro.redirect('/gelismeler');
}

const pageTitle = post.title
  ? `${post.title} | itüöder`
  : 'itüöder – Gelişmeler';

// İçerik var mı? (slug ile çekildiğinde gelir)
const hasContent = Boolean(post.content && post.content.trim().length > 0);
---

<Layout title={pageTitle}>

  <!-- ─── HERO / COVER ─── -->
  <section class="relative overflow-hidden">
    <!-- Kapak görseli varsa büyük hero, yoksa gradient alan -->
    {post.cover_image ? (
      <div class="relative h-[60vh] min-h-[400px] max-h-[600px] w-full overflow-hidden">
        <img
          src={post.cover_image}
          alt={post.title}
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#1B1B1B]/70 via-[#1B1B1B]/20 to-transparent"></div>

        <!-- Overlay içerik -->
        <div class="absolute bottom-0 left-0 right-0">
          <div class="site-shell pb-10 pt-6">
            <!-- Breadcrumb -->
            <nav class="mb-4 flex items-center gap-2 text-xs text-white/60">
              <a href="/" class="hover:text-white transition">Ana Sayfa</a>
              <span>/</span>
              <a href="/gelismeler" class="hover:text-white transition">Gelişmeler</a>
              <span>/</span>
              <span class="text-white/40 text-clamp-3" style="max-width: 30ch;">{post.title}</span>
            </nav>

            {post.tags && post.tags.length > 0 && (
              <div class="mb-3 flex flex-wrap gap-2">
                {post.tags.map((tag) => (
                  <span class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-widest text-white backdrop-blur-sm">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <h1 class="max-w-[20ch] font-display text-3xl font-extrabold leading-tight text-white sm:text-4xl lg:text-5xl">
              {post.title}
            </h1>

            <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-white/60">
              {post.published_at && (
                <span>{formatDate(post.published_at)}</span>
              )}
              {post.read_time && (
                <>
                  <span class="h-px w-4 bg-white/30"></span>
                  <span>{post.read_time}</span>
                </>
              )}
            </div>
          </div>
        </div>
      </div>
    ) : (
      <!-- Kapak yok: gradient hero -->
      <div class="section-space relative overflow-hidden pb-8">
        <div class="pointer-events-none absolute -left-20 top-4 h-[28rem] w-[28rem] rounded-full bg-[#FF9700]/12 blur-[130px]"></div>
        <div class="pointer-events-none absolute right-0 top-20 h-[24rem] w-[24rem] rounded-full bg-[#1B1B1B]/6 blur-[110px]"></div>

        <div class="site-shell relative z-10">
          <!-- Breadcrumb -->
          <nav class="mb-6 flex items-center gap-2 text-xs text-[#1B1B1B]/50">
            <a href="/" class="hover:text-[#FF9700] transition">Ana Sayfa</a>
            <span>/</span>
            <a href="/gelismeler" class="hover:text-[#FF9700] transition">Gelişmeler</a>
            <span>/</span>
            <span class="text-[#1B1B1B]/30">{post.title}</span>
          </nav>

          {post.tags && post.tags.length > 0 && (
            <div class="mb-4 flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="eyebrow">{tag}</span>
              ))}
            </div>
          )}

          <h1 class="section-title max-w-[20ch]">{post.title}</h1>

          <div class="mt-5 flex flex-wrap items-center gap-4 text-sm text-[#1B1B1B]/50">
            {post.published_at && (
              <span>{formatDate(post.published_at)}</span>
            )}
            {post.read_time && (
              <>
                <span class="h-px w-4 bg-[#1B1B1B]/20"></span>
                <span>{post.read_time}</span>
              </>
            )}
          </div>
        </div>
      </div>
    )}
  </section>

  <!-- ─── ÖZET / SUMMARY ─── -->
  {post.summary && (
    <section class={post.cover_image ? 'section-space-tight' : 'pb-0'}>
      <div class="site-shell">
        <div class="mx-auto max-w-3xl">
          <p class="border-l-4 border-[#FF9700] pl-5 text-lg leading-8 text-[#1B1B1B]/70 italic">
            {post.summary}
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- ─── MAKALE İÇERİĞİ ─── -->
  <section class="section-space-tight pb-16">
    <div class="site-shell">
      <div class="mx-auto max-w-3xl">

        {fetchError && (
          <div class="mb-8 rounded-2xl border border-[#1B1B1B]/10 bg-[#F5F5F7] p-5 text-sm text-[#1B1B1B]/60">
            İçerik yüklenirken bir sorun oluştu. Kısmi bilgi gösteriliyor.
          </div>
        )}

        {hasContent ? (
          <!-- API'dan gelen HTML içerik -->
          <div class="post-content" set:html={post.content} />
        ) : (
          <!-- İçerik henüz yok -->
          <div class="rounded-[1.9rem] border border-[#1B1B1B]/10 bg-[#F5F5F7] p-8 text-center">
            <div class="icon-chip mx-auto mb-4 h-14 w-14 rounded-2xl text-[#FF9700]">
              <AppIcon name="document" class="h-6 w-6" />
            </div>
            <p class="mb-2 font-bold text-[#1B1B1B]">İçerik yakında yayınlanacak</p>
            <p class="text-sm text-[#1B1B1B]/60">Bu yazının tam içeriği henüz eklenmedi.</p>
          </div>
        )}

        <!-- Etiketler -->
        {post.tags && post.tags.length > 0 && (
          <div class="mt-12 flex flex-wrap items-center gap-2 border-t border-[#1B1B1B]/10 pt-8">
            <span class="text-xs font-semibold uppercase tracking-widest text-[#1B1B1B]/40">Etiketler:</span>
            {post.tags.map((tag) => (
              <span class="rounded-full border border-[#1B1B1B]/10 bg-[#F5F5F7] px-4 py-1.5 text-xs font-semibold text-[#1B1B1B]/60">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Navigasyon -->
        <div class="mt-10 flex items-center justify-between">
          <a
            href="/gelismeler"
            class="inline-flex items-center gap-2 rounded-full border border-[#1B1B1B]/10 bg-white px-5 py-2.5 text-sm font-semibold text-[#1B1B1B] transition hover:border-[#1B1B1B] hover:bg-[#1B1B1B] hover:text-white"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Tüm Gelişmeler
          </a>
          <a
            href="/uye-ol"
            class="btn btn-primary rounded-full px-6 py-2.5 text-sm shadow-[0_8px_24px_rgba(255,151,0,0.25)]"
          >
            Üye Ol
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ─── Post İçerik Stilleri ─────────────────────────────────────────────────── */
  .post-content {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: rgba(27, 27, 27, 0.82);
  }

  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4 {
    font-family: "Coolvetica", "Arial Narrow", Arial, sans-serif;
    color: #1B1B1B;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .post-content h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); }
  .post-content h3 { font-size: clamp(1.2rem, 2vw, 1.5rem); }
  .post-content h4 { font-size: 1.125rem; }

  .post-content p {
    margin-bottom: 1.5rem;
  }

  .post-content a {
    color: #FF9700;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 150ms ease;
  }
  .post-content a:hover { opacity: 0.75; }

  .post-content ul,
  .post-content ol {
    margin: 1.25rem 0 1.5rem 1.5rem;
  }
  .post-content ul { list-style-type: disc; }
  .post-content ol { list-style-type: decimal; }
  .post-content li { margin-bottom: 0.5rem; }

  .post-content blockquote {
    border-left: 4px solid #FF9700;
    background: rgba(255, 151, 0, 0.06);
    border-radius: 0 1rem 1rem 0;
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    font-style: italic;
    color: rgba(27, 27, 27, 0.7);
  }

  .post-content img {
    border-radius: 1.25rem;
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    display: block;
    box-shadow: 0 8px 32px rgba(27, 27, 27, 0.1);
  }

  .post-content hr {
    border: none;
    border-top: 1px solid rgba(27, 27, 27, 0.1);
    margin: 2.5rem 0;
  }

  .post-content strong { color: #1B1B1B; font-weight: 700; }
  .post-content em { font-style: italic; }

  .post-content code {
    background: rgba(27, 27, 27, 0.06);
    border-radius: 0.375rem;
    padding: 0.15em 0.45em;
    font-size: 0.9em;
    font-family: "Courier New", monospace;
  }

  .post-content pre {
    background: #1B1B1B;
    border-radius: 1rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .post-content pre code {
    background: transparent;
    color: #fff;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .post-content th {
    background: #F5F5F7;
    font-weight: 700;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 2px solid rgba(27,27,27,0.1);
  }
  .post-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(27,27,27,0.08);
  }
</style>
