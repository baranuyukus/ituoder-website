<script>
  function selectAmount(amount: number, btn: HTMLElement) {
    const btns = document.querySelectorAll('.amount-btn');
    btns.forEach(b => {
      b.classList.remove('border-[#FF9700]', 'bg-[#FF9700]/20', 'text-[#FF9700]');
      b.classList.add('border-white/20', 'bg-white/10', 'text-white');
    });
    btn.classList.remove('border-white/20', 'bg-white/10', 'text-white');
    btn.classList.add('border-[#FF9700]', 'bg-[#FF9700]/20', 'text-[#FF9700]');
    const customInput = document.getElementById('custom-amount') as HTMLInputElement;
    if (customInput) customInput.value = '';
  }

  function clearSelection() {
    const btns = document.querySelectorAll('.amount-btn');
    btns.forEach(b => {
      b.classList.remove('border-[#FF9700]', 'bg-[#FF9700]/20', 'text-[#FF9700]');
      b.classList.add('border-white/20', 'bg-white/10', 'text-white');
    });
  }

  (window as any).selectAmount = selectAmount;
  (window as any).clearSelection = clearSelection;
</script>
