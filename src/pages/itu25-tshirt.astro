---
import Layout from '../layouts/Layout.astro';
---

<Layout title="itüöder - ITU 25 Tişört">

  <section class="section-space relative overflow-hidden">
    <div class="pointer-events-none absolute -top-32 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-[#FF9700]/12 blur-[140px]"></div>

    <div class="site-shell relative z-10">
      <div class="mx-auto max-w-3xl text-center space-y-8">
        <span class="eyebrow mb-4 inline-block">Saha Projeleri</span>

        <!-- Başvuru Durumu -->
        <div class="inline-flex rounded-full border border-[#FF9700]/20 bg-[#FF9700]/[0.08] px-5 py-3 text-sm font-semibold text-[#B36B00]">
          Tişört başvuruları 31 Mayıs 00:00 itibari ile sonlanmıştır. İlginiz için çok teşekkür ederiz.
        </div>

        <h1 class="section-title">
          ITU 25: <span class="text-[#FF9700]">THE GENESIS.</span>
        </h1>

        <p class="mx-auto max-w-2xl text-lg leading-8 text-[#1B1B1B]/70">
          İTÜ öğrencileri olarak senelerdir uygun fiyatlı, kaliteli ve gururla taşıyacağımız
          tasarımları olan bir parçaya hasretiz; bunu artık bitiriyoruz.
        </p>

        <p class="mx-auto max-w-2xl text-lg leading-8 text-[#1B1B1B]/70">
          Her yıl &mdash; sadece o yıla özel &mdash; İTÜ'de yaşadıklarımızın hafızası olarak bir tişört yaratacağız.
          Bu geleneğin ilkiyle sizi tanıştıralım&hellip;
        </p>

        <!-- Bağış Notu -->
        <div class="surface-card mx-auto max-w-xl p-7 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#FF9700]/10">
            <svg class="h-6 w-6 text-[#FF9700]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <p class="text-base leading-relaxed text-[#1B1B1B]/70">
            Üretim maliyeti dışında tüm bağışlar
            <a href="/psikolojik-destek" class="font-semibold text-[#FF9700] hover:underline">Psikolojik Destek</a>
            projesine aktarılacaktır.
          </p>
        </div>

        <a href="/saha-projeleri" class="btn btn-primary rounded-full px-8 py-3.5 text-base font-bold shadow-[0_16px_40px_rgba(255,151,0,0.3)]">
          Saha Projelerini İncele
        </a>
      </div>
    </div>
  </section>

</Layout>
