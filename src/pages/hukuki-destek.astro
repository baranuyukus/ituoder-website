---
import Layout from '../layouts/Layout.astro';

const steps = [
  {
    step: '01',
    title: 'itüöder üyesi ol',
    description: 'Hukuki destek paneline ulaşmak istiyorsan itüöder üyesi olman gerekiyor.',
    actionLabel: 'itüöder üyesi ol',
    actionHref: '/uye-ol',
  },
  {
    step: '02',
    title: 'Formu doldur',
    description: 'Hukuki destek almak istiyorsan formu doldur. Paylaştığın bilgiler gizli tutulacak ve yalnızca ilgili avukata ulaştırılacaktır.',
    actionLabel: 'Hukuki Destek Formu',
    actionHref: '#',
  },
  {
    step: '03',
    title: 'Avukat yönlendirmesi',
    description: 'Seninle en kısa sürede iletişime geçerek en uygun avukata yönlendireceğiz. Süreç seninle başlar.',
  },
];

const highlights = [
  'Hukuki süreçlerde bilinçli adım atmanı kolaylaştırır.',
  'Avukat desteğiyle haklarını öğrenir ve savunursun.',
  'Bilgilerin gizli tutulur, yalnızca ilgili avukata ulaştırılır.',
  'Çözüm yolculuğunda sana rehberlik edilir.',
];
---

<Layout title="itüöder - Hukuki Destek">
  <!-- ─── HERO ─── -->
  <section class="section-space relative overflow-hidden pb-8">
    <div class="pointer-events-none absolute -left-24 top-0 h-[30rem] w-[30rem] rounded-full bg-[#FF9700]/10 blur-[130px]"></div>
    <div class="pointer-events-none absolute right-0 top-16 h-[26rem] w-[26rem] rounded-full bg-[#1B1B1B]/5 blur-[120px]"></div>
    <div class="pointer-events-none absolute left-[42%] top-24 h-[24rem] w-[24rem] rounded-full bg-[#9B2330]/10 blur-[120px]"></div>

    <div class="site-shell relative z-10 grid gap-8 xl:grid-cols-[minmax(0,1.02fr)_minmax(24rem,0.88fr)] xl:items-center">
      <div class="space-y-7">
        <div class="flex flex-wrap items-center gap-3">
          <span class="eyebrow hak-chip">Hukuki Destek</span>
          <span class="inline-flex items-center rounded-full border border-[color:var(--brand-outline)] bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-[#1B1B1B]/56 shadow-[0_10px_24px_rgba(155,35,48,0.08)]">
            hak'lısın projesi
          </span>
        </div>

        <div class="space-y-5">
          <h1 class="section-title max-w-[11ch]">
            Hukuki sorunlarında yalnız değilsin. Endişelenme. Senin için buradayız.
          </h1>
          <p class="max-w-[39rem] text-lg leading-8 text-[#1B1B1B]/70">
            <span class="font-semibold text-[#9B2330]">hak'lısın</span>, İTÜ öğrencilerinin karşılaştığı hukuki
            meselelerde yalnız bırakmamak ve haklarını bilmeleri ile savunmaları konusunda avukat desteği sağlayan
            bir projedir. Öğrencilerin karşılaştıkları hukuki durumlarda bilinçli adımlar atmalarını kolaylaştıran
            uygulamalar sunar ve çözüm yolculuklarında rehberlik eder.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="#" class="btn btn-primary btn-lg rounded-full px-8 shadow-[0_18px_40px_rgba(255,151,0,0.22)]">
            Şimdi Talep Et
          </a>
          <a href="/uye-ol" class="btn btn-lg rounded-full border border-[#9B2330]/20 bg-[#9B2330]/[0.08] px-8 text-[#7A1B26] shadow-[0_14px_30px_rgba(155,35,48,0.12)] hover:border-[#9B2330] hover:bg-[#9B2330] hover:text-white">
            Üye Ol
          </a>
        </div>

        <div class="inline-flex rounded-full border border-[#9B2330]/20 bg-[#9B2330]/[0.08] px-4 py-2.5 text-sm font-semibold text-[#7A1B26]">
          Destekten sadece itüöder üyeleri faydalanabilir.
        </div>
      </div>

      <!-- ─── ASIDE KART ─── -->
      <aside class="surface-card relative overflow-hidden p-4 sm:p-5">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,151,0,0.12),transparent_16rem),radial-gradient(circle_at_bottom_right,rgba(155,35,48,0.14),transparent_18rem)]"></div>
        <div class="relative hak-soft rounded-[1.85rem] border p-6 sm:p-7">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <img src="/hukuki-destek/project-logo-black.webp" alt="hak'lısın hukuki destek logosu" class="h-16 w-auto object-contain sm:h-20" />
            <div class="rounded-[1.2rem] border border-[#9B2330]/16 bg-white px-4 py-3 text-right shadow-[0_12px_24px_rgba(155,35,48,0.08)]">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#1B1B1B]/42">Gizlilik</p>
              <p class="mt-1 font-display text-lg font-bold text-[#9B2330]">%100</p>
            </div>
          </div>

          <div class="mt-8 grid gap-4 sm:grid-cols-[1fr_0.92fr]">
            <div class="hak-dark rounded-[1.5rem] p-5 text-white shadow-[0_22px_50px_rgba(155,35,48,0.16)]">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[#F5A0A8]/72">Kimin için?</p>
              <p class="mt-3 max-w-[15ch] font-display text-[1.8rem] font-bold leading-[1.02]">
                Hukuki süreçlerde yalnız kalmak istemeyen İTÜ öğrencileri için.
              </p>
            </div>

            <div class="hak-card rounded-[1.5rem] border p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[#7A1B26]">Avukat desteği</p>
              <img src="/hukuki-destek/students-together.webp" alt="hukuki destek alan öğrenciler" class="mt-3 w-full rounded-[1.25rem] object-cover" />
            </div>
          </div>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <div class="rounded-[1.45rem] border border-[#9B2330]/18 bg-[#9B2330]/[0.07] p-4">
              <img src="/hukuki-destek/student-male.webp" alt="hukuki destek erkek öğrenci illüstrasyonu" class="mx-auto h-32 w-32 object-contain" />
              <p class="mt-3 text-center text-sm leading-7 text-[#1B1B1B]/66">
                Haklarını bilmek, kendini savunmanın ilk adımı.
              </p>
            </div>
            <div class="rounded-[1.45rem] border border-[#9B2330]/16 bg-white p-4 shadow-[0_14px_28px_rgba(155,35,48,0.08)]">
              <img src="/hukuki-destek/student-female.webp" alt="hukuki destek kadın öğrenci illüstrasyonu" class="mx-auto h-32 w-32 object-contain" />
              <p class="mt-3 text-center text-sm leading-7 text-[#1B1B1B]/66">
                Gizlilik ön planda; bilgilerin yalnızca avukatına ulaşır.
              </p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ─── NASIL ÇALIŞIR ─── -->
  <section id="surec" class="section-space-tight pt-2">
    <div class="site-shell">
      <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-4">
          <span class="eyebrow hak-chip">Nasıl çalışır?</span>
          <h2 class="section-title max-w-[11ch]">
            Süreci kısa, güvenli ve gizli tutarak tasarladık.
          </h2>
        </div>
        <p class="max-w-[34rem] text-base leading-8 text-[#1B1B1B]/66">
          Başvuru formundan avukat yönlendirmesine kadar akış net. Bilgilerin gizli kalır ve yalnızca ilgili avukata ulaştırılır.
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {steps.map((item, index) => (
          <article class:list={[
            'surface-card flex h-full flex-col p-6 sm:p-7',
            index === 0 ? 'hak-card shadow-[0_20px_44px_rgba(155,35,48,0.08)]' : '',
            index === 2 ? 'bg-[linear-gradient(180deg,#3D0E14_0%,#5A1520_40%,#1B1B1B_100%)] text-white shadow-[0_24px_55px_rgba(155,35,48,0.18)]' : '',
          ]}>
            <span class:list={[
              'inline-flex h-12 w-12 items-center justify-center rounded-full text-sm font-semibold',
              index === 2
                ? 'bg-[#9B2330]/18 text-white'
                : 'border border-[#9B2330]/18 bg-[#9B2330]/[0.08] text-[#7A1B26]',
            ]}>
              {item.step}
            </span>

            <h3 class:list={[
              'mt-6 font-display text-[1.8rem] font-bold leading-[1.04]',
              index === 2 ? 'text-white' : 'text-[#1B1B1B]',
            ]}>
              {item.title}
            </h3>

            <p class:list={[
              'mt-4 text-sm leading-7',
              index === 2 ? 'text-white/72' : 'text-[#1B1B1B]/68',
            ]}>
              {item.description}
            </p>

            {item.actionLabel && item.actionHref && (
              <a
                href={item.actionHref}
                class:list={[
                  'mt-6 inline-flex items-center gap-2 text-sm font-semibold',
                  index === 2 ? 'text-[#F5A0A8]' : 'text-[#9B2330]',
                ]}
              >
                {item.actionLabel}
                <span aria-hidden="true">→</span>
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── GİZLİLİK + PROJE DETAYLARI ─── -->
  <section class="section-space">
    <div class="site-shell grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <!-- Gizlilik Vurgusu -->
      <div class="surface-card hak-soft p-7 sm:p-8">
        <span class="eyebrow hak-chip">Neden güvenli?</span>
        <h2 class="mt-5 font-display text-[2.3rem] font-bold leading-[1.02] text-[#1B1B1B] sm:text-[2.8rem]">
          Gizliliğin bizim için öncelik. Sürecin her aşamasında bilgilerin korunur.
        </h2>
        <p class="mt-4 text-base leading-8 text-[#1B1B1B]/68">
          hak'lısın projesi, öğrencilerin hukuki süreçlerde yalnız kalmadan bilinçli adımlar atmasını sağlar.
          Tüm bilgiler yalnızca ilgili avukata iletilir.
        </p>

        <div class="mt-7 space-y-3">
          {highlights.map((item) => (
            <div class="rounded-[1.35rem] border border-[#9B2330]/18 bg-[#9B2330]/[0.07] px-4 py-4 text-sm leading-7 text-[#1B1B1B]/70">
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- Proje Kimlik Kartı -->
      <article class="overflow-hidden rounded-[2rem] border border-[#9B2330]/16 bg-[linear-gradient(145deg,#2D0A10_0%,#4A141C_38%,#1B1B1B_100%)] text-white shadow-[0_28px_70px_rgba(155,35,48,0.16)]">
        <div class="grid gap-0 md:grid-cols-[0.86fr_1.14fr] md:items-stretch">
          <div class="flex items-center justify-center bg-[linear-gradient(180deg,rgba(155,35,48,0.14),transparent)] p-6">
            <img src="/hukuki-destek/student-female.webp" alt="hukuki destek alan öğrenci illüstrasyonu" class="h-56 w-auto object-contain sm:h-64" />
          </div>

          <div class="flex flex-col justify-center p-7 sm:p-8">
            <span class="eyebrow border-[#9B2330]/16 bg-[#9B2330]/12 text-[#F5A0A8]">hak'lısın</span>
            <blockquote class="mt-5 font-display text-[1.8rem] font-bold leading-[1.08] text-white sm:text-[2.2rem]">
              "Haklarını bilmek, kendini savunmanın ilk adımıdır."
            </blockquote>
            <p class="mt-6 text-sm uppercase tracking-[0.2em] text-white/46">itüöder Hukuki Destek</p>

            <div class="mt-8">
              <img src="/hukuki-destek/project-logo-white.webp" alt="hak'lısın logosu" class="h-12 w-auto object-contain opacity-80" />
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="section-space-tight pt-0">
    <div class="site-shell">
      <div class="overflow-hidden rounded-[2.35rem] border border-[#9B2330]/16 bg-[linear-gradient(135deg,#2D0A10_0%,#501820_40%,#1B1B1B_100%)] text-white shadow-[0_28px_70px_rgba(155,35,48,0.16)]">
        <div class="grid gap-8 p-7 sm:p-9 lg:grid-cols-[minmax(0,0.95fr)_minmax(17rem,0.7fr)] lg:items-center lg:p-12">
          <div>
            <span class="eyebrow border-[#9B2330]/16 bg-[#9B2330]/12 text-[#F5A0A8]">Süreci başlat</span>
            <h2 class="mt-5 font-display text-[2.35rem] font-bold leading-[1.02] text-white sm:text-[3rem]">
              Haklarını bilmek, ilk adım.
            </h2>
            <p class="mt-4 max-w-[34rem] text-base leading-8 text-white/72">
              Hukuki süreçlerde yalnız kalma. itüöder üyesi olarak avukat desteğine kolayca ulaşabilirsin.
              Formu doldur, biz seninle iletişime geçelim.
            </p>
          </div>

          <div class="grid gap-3">
            <a href="#" class="btn btn-primary btn-lg rounded-full px-8 shadow-[0_18px_40px_rgba(255,151,0,0.24)]">
              Şimdi Talep Et
            </a>
            <a href="/uye-ol" class="btn btn-lg rounded-full border border-white/12 bg-white/[0.08] px-8 text-white shadow-none hover:bg-white hover:text-[#1B1B1B]">
              Önce Üye Ol
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hak-chip {
    border-color: rgba(155, 35, 48, 0.18);
    background: rgba(155, 35, 48, 0.08);
    color: #7a1b26;
  }

  .hak-card {
    border-color: rgba(155, 35, 48, 0.18);
    background: linear-gradient(180deg, rgba(155, 35, 48, 0.08) 0%, #ffffff 76%);
  }

  .hak-soft {
    border-color: rgba(155, 35, 48, 0.16);
    background: linear-gradient(180deg, rgba(155, 35, 48, 0.08) 0%, #f5f5f7 100%);
  }

  .hak-dark {
    background: linear-gradient(145deg, #2d0a10 0%, #4a141c 52%, #1b1b1b 100%);
  }
</style>
