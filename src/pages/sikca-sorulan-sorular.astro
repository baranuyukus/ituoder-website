---
import Layout from '../layouts/Layout.astro';
import { faqHighlights, faqSections } from '../data/faq';

const quickLinks = faqSections.map((section, index) => ({
  ...section,
  order: `0${index + 1}`,
}));
---

<Layout title="itüöder - Sıkça Sorulan Sorular">
  <section class="section-space relative overflow-hidden pb-8">
    <div class="pointer-events-none absolute -left-24 top-0 h-[30rem] w-[30rem] rounded-full bg-[#FF9700]/10 blur-[130px]"></div>
    <div class="pointer-events-none absolute right-0 top-20 h-[24rem] w-[24rem] rounded-full bg-[#1B1B1B]/5 blur-[110px]"></div>

    <div class="site-shell relative z-10 grid gap-8 xl:grid-cols-[minmax(0,0.92fr)_minmax(21rem,0.72fr)] xl:items-start">
      <div class="space-y-7">
        <span class="eyebrow">S.S.S.</span>
        <div class="space-y-5">
          <h1 class="section-title max-w-[11ch]">
            itüöder hakkında en çok merak edilenleri tek yerde topladık.
          </h1>
          <p class="max-w-[40rem] text-lg leading-8 text-[#1B1B1B]/70">
            Derneğin yapısından üyelik sürecine, gönüllülükten bağış desteğine kadar en çok gelen soruların
            cevapları burada. Aradığın başlığa hızlıca geçebilir ya da tüm sayfayı adım adım inceleyebilirsin.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          {quickLinks.map((section) => (
            <a
              href={`#${section.id}`}
              class="inline-flex items-center gap-2 rounded-full border border-[color:var(--brand-outline)] bg-white px-4 py-2.5 text-sm font-semibold text-[#1B1B1B] transition hover:border-[#FF9700]/24 hover:bg-[#F5F5F7]"
            >
              <span class="text-[#1B1B1B]/38">{section.order}</span>
              <span>{section.eyebrow}</span>
            </a>
          ))}
        </div>
      </div>

      <aside class="surface-card relative overflow-hidden p-6 sm:p-7">
        <div class="absolute inset-x-0 top-0 h-28 bg-[linear-gradient(180deg,rgba(255,151,0,0.08),transparent)]"></div>
        <div class="relative">
          <img src="/home/logo-long.png" alt="itüöder logosu" class="h-12 w-auto object-contain sm:h-14" />
          <p class="mt-5 max-w-[26rem] text-base leading-7 text-[#1B1B1B]/70">
            Cevabını bulamazsan bize doğrudan yazabilirsin. Üyelik, gönüllülük ve kurumsal iş birlikleri için
            hızlı dönüş yapmaya özen gösteriyoruz.
          </p>

          <div class="mt-6 grid gap-3">
            {faqHighlights.map((item) => (
              <div class="rounded-[1.45rem] border border-[color:var(--brand-outline)] bg-[#F5F5F7] p-4">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="font-display text-[1.7rem] font-bold leading-none text-[#1B1B1B]">{item.value}</span>
                  <span class="text-xs font-semibold uppercase tracking-[0.22em] text-[#1B1B1B]/38">{item.label}</span>
                </div>
                <p class="mt-3 text-sm leading-7 text-[#1B1B1B]/65">{item.description}</p>
              </div>
            ))}
          </div>

          <a
            href="mailto:dernek@ituogrenci.org.tr"
            class="mt-6 flex items-center justify-between rounded-[1.45rem] bg-[#1B1B1B] px-5 py-4 text-white transition hover:shadow-[0_16px_36px_rgba(27,27,27,0.16)]"
          >
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-white/46">İletişim</p>
              <p class="mt-1 text-base font-semibold">dernek@ituogrenci.org.tr</p>
            </div>
            <span aria-hidden="true" class="text-lg">→</span>
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-space-tight pt-0">
    <div class="site-shell grid gap-8 xl:grid-cols-[18rem_minmax(0,1fr)]">
      <aside class="hidden xl:block">
        <div class="sticky top-32 space-y-4">
          <div class="surface-card p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#1B1B1B]/42">Hızlı Gezin</p>
            <div class="mt-4 space-y-2.5">
              {quickLinks.map((section) => (
                <a
                  href={`#${section.id}`}
                  class="flex items-center justify-between rounded-[1.2rem] border border-[color:var(--brand-outline)] bg-[#F5F5F7] px-4 py-3 text-sm font-semibold text-[#1B1B1B] transition hover:border-[#FF9700]/24 hover:bg-white"
                >
                  <span>{section.title}</span>
                  <span class="text-[#1B1B1B]/34">{section.order}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="surface-card p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#1B1B1B]/42">Yardıma mı ihtiyacın var?</p>
            <p class="mt-3 text-sm leading-7 text-[#1B1B1B]/68">
              Cevabını burada bulamadıysan iletişim sayfasından yazabilir ya da doğrudan mail gönderebilirsin.
            </p>
            <a href="/iletisim" class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[#1B1B1B]">
              İletişim sayfasına git
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </aside>

      <div class="space-y-6">
        {faqSections.map((section, sectionIndex) => (
          <section id={section.id} class="surface-card scroll-mt-32 p-6 sm:p-8 lg:p-10">
            <div class="flex flex-col gap-4 border-b border-[color:var(--brand-outline)] pb-6 sm:flex-row sm:items-end sm:justify-between">
              <div class="space-y-3">
                <span class="eyebrow">{section.eyebrow}</span>
                <h2 class="font-display text-[2rem] font-bold leading-[1.02] text-[#1B1B1B] sm:text-[2.45rem]">
                  {section.title}
                </h2>
              </div>
              <p class="max-w-[32rem] text-sm leading-7 text-[#1B1B1B]/66">
                {section.description}
              </p>
            </div>

            <div class="mt-6 space-y-4">
              {section.items.map((item, itemIndex) => (
                <details class="faq-item rounded-[1.6rem] border" open={itemIndex === 0 && sectionIndex === 0}>
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-5 sm:p-6">
                    <div class="flex items-start gap-4">
                      <span class="faq-order inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border border-[color:var(--brand-outline)] bg-white text-xs font-semibold text-[#1B1B1B]/48">
                        {String(itemIndex + 1).padStart(2, '0')}
                      </span>
                      <span class="pr-2 text-lg font-semibold leading-7 text-[#1B1B1B] sm:text-[1.2rem]">
                        {item.question}
                      </span>
                    </div>
                    <span class="faq-icon inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-[#F5F5F7] text-[1.6rem] leading-none text-[#1B1B1B]">
                      +
                    </span>
                  </summary>

                  <div class="px-5 pb-5 sm:px-6 sm:pb-6">
                    <div class="ml-14 border-l border-[color:var(--brand-outline)] pl-5">
                      <div class="space-y-4 text-sm leading-7 text-[#1B1B1B]/72 sm:text-base">
                        {item.answer.map((paragraph) => (
                          <p>{paragraph}</p>
                        ))}
                      </div>

                      {item.action && (
                        <a
                          href={item.action.href}
                          class="mt-5 inline-flex items-center gap-2 rounded-full border border-[color:var(--brand-outline)] bg-white px-4 py-2.5 text-sm font-semibold text-[#1B1B1B] transition hover:border-[#FF9700]/24 hover:bg-[#F5F5F7]"
                        >
                          {item.action.label}
                          <span aria-hidden="true">→</span>
                        </a>
                      )}
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="site-shell">
      <div class="overflow-hidden rounded-[2.3rem] border border-[color:var(--brand-outline)] bg-[#1B1B1B] text-white shadow-[0_28px_70px_rgba(27,27,27,0.16)]">
        <div class="grid gap-8 p-7 sm:p-9 lg:grid-cols-[minmax(0,0.96fr)_minmax(18rem,0.74fr)] lg:items-center lg:p-12">
          <div>
            <span class="eyebrow border-white/10 bg-white/[0.08] text-white/80">Hala aklında soru mu var?</span>
            <h2 class="mt-5 font-display text-[2.3rem] font-bold leading-[1.02] text-white sm:text-[3rem]">
              Topluluğa katıl, detayları bizimle doğrudan konuş.
            </h2>
            <p class="mt-4 max-w-[34rem] text-base leading-8 text-white/72">
              Üyelik, gönüllülük, destek mekanizmaları ya da kurum iş birlikleri konusunda sana doğru kanaldan hızlıca yardımcı olalım.
            </p>
          </div>

          <div class="grid gap-3">
            <a href="/uye-ol" class="btn btn-primary btn-lg rounded-full px-8 shadow-[0_18px_40px_rgba(255,151,0,0.24)]">
              Üye Ol
            </a>
            <a href="/iletisim" class="btn btn-lg rounded-full border border-white/12 bg-white/10 px-8 text-white shadow-none hover:bg-white hover:text-[#1B1B1B]">
              İletişime Geç
            </a>
            <a href="/bagisci-ol" class="btn btn-lg rounded-full border border-white/12 bg-transparent px-8 text-white shadow-none hover:bg-white/10">
              Bağışçı Ol
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-item {
    border-color: var(--brand-outline);
    background: rgba(245, 245, 247, 0.78);
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .faq-item[open] {
    background: rgba(255, 255, 255, 0.96);
    border-color: rgba(255, 151, 0, 0.2);
    box-shadow: 0 18px 40px rgba(27, 27, 27, 0.06);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item .faq-icon,
  .faq-item .faq-order {
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    background: #ff9700;
    color: #ffffff;
  }

  .faq-item[open] .faq-order {
    border-color: rgba(255, 151, 0, 0.2);
    background: rgba(255, 151, 0, 0.08);
    color: rgba(27, 27, 27, 0.74);
  }
</style>
